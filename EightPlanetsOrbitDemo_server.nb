(* \:901a\:8fc7\[OpenCurlyDoubleQuote]\:89d2\:901f\:5ea6 = 2 Pi / \
\:516c\:8f6c\:5468\:671f\[CloseCurlyDoubleQuote]\:7684\:7b80\:5316\:6a21\:578b\
\:ff0c\:8ba1\:7b97\:884c\:661f\:5728\:65f6\:523b t \:7684\:4e8c\:7ef4\:4f4d\
\:7f6e\:3002
   \:8fd9\:4e2a\:793a\:4f8b\:4e0d\:662f\:9ad8\:7cbe\:5ea6\:5929\:4f53\:529b\
\:5b66\:6a21\:62df\:ff0c\:800c\:662f\:4e00\:4e2a\:4fbf\:4e8e\:5c55\:793a\:548c\
\:6559\:5b66\:7684\:53ef\:89c6\:5316\:8fd1\:4f3c\:6a21\:578b\:ff0c
   \:6240\:4ee5\:8f68\:9053\:7edf\:4e00\:6309\:5706\:8f68\:9053\:5904\:7406\
\:ff0c\:91cd\:70b9\:662f\:770b\:6e05\:516b\:5927\:884c\:661f\:7684\:76f8\:5bf9\
\:8fd0\:52a8\:8282\:594f\:3002 *)
planetPosition[planet_, t_] := Module[
  {theta = 2 Pi t/planet[\"\:516c\:8f6c\:5468\:671f\"]},
  planet[\"\:8f68\:9053\:534a\:5f84\"] {Cos[theta], Sin[theta]}
];

(* \:4e3a\:6bcf\:9897\:884c\:661f\:751f\:6210\:4e00\:5c0f\:6bb5\
\[OpenCurlyDoubleQuote]\:6700\:8fd1\:8fd0\:52a8\:8f68\:8ff9\
\[CloseCurlyDoubleQuote]\:3002
   \:8fd9\:6837\:753b\:51fa\:6765\:7684\:4e0d\:662f\:6574\:5708\:5b9e\:7ebf\
\:ff0c\:800c\:662f\:5e26\:6709\:65f6\:95f4\:611f\:7684\:5f69\:8272\:5c3e\:8ff9\
\:ff0c
   \:66f4\:5bb9\:6613\:770b\:51fa\:52a8\:753b\:6b63\:5728\:8fd0\:52a8\:ff0c\
\:800c\:4e0d\:662f\:4e00\:5f20\:9759\:6001\:8f68\:9053\:56fe\:3002 *)
trailPoints[planet_, t_] := Table[
  planetPosition[planet, tau],
  {
    tau,
    Max[0., t - Min[1.2, planet[\"\:516c\:8f6c\:5468\:671f\"]]],
    t,
    Max[0.01, planet[\"\:516c\:8f6c\:5468\:671f\"]/150.]
  }
];

(* \:5916\:884c\:661f\:7684\:8f68\:9053\:534a\:5f84\:5f88\:5927\:ff0c\:5982\
\:679c\:5706\:70b9\:56fa\:5b9a\:8fc7\:5c0f\:ff0c\:5728\:5168\:666f\:89c6\:56fe\
\:91cc\:4f1a\:4e0d\:5bb9\:6613\:8fa8\:8ba4\:3002
   \:8fd9\:91cc\:4f7f\:7528\:4e00\:4e2a\:5bf9\:6570\:5c3a\:5ea6\:ff0c\:8ba9\
\:8fdc\:5904\:884c\:661f\:4ecd\:7136\:53ef\:89c1\:ff0c\:4f46\:53c8\:4e0d\:4f1a\
\:5938\:5f20\:5230\:5931\:771f\:3002 *)
planetDiskRadius[planet_] := 0.045 + 0.012 Log[1 + \
planet[\"\:8f68\:9053\:534a\:5f84\"]];

(* \:8fd9\:662f\:5b9e\:9645\:7ed8\:56fe\:51fd\:6570\:3002
   showTrails \:63a7\:5236\:662f\:5426\:663e\:793a\:5f69\:8272\:5c3e\:8ff9\
\:ff1b
   zoom \:63a7\:5236\:89c6\:91ce\:534a\:5f84\:ff0c\:53ea\:663e\:793a\:8f68\
\:9053\:534a\:5f84\:4e0d\:8d85\:8fc7\:5f53\:524d\:89c6\:91ce\:7684\:884c\:661f\
\:ff1b
   t \:5219\:8868\:793a\:6a21\:62df\:5230\:7b2c\:51e0\:5e74\:3002 *)
orbitGraphic[t_, showTrails_, zoom_] := Module[
  {visiblePlanets, range},
  visiblePlanets = Select[planetData, #[\"\:8f68\:9053\:534a\:5f84\"] <= zoom \
&];
  range = 1.08 zoom;

  Graphics[
    Join[
      {
        (* \:592a\:9633\:4f7f\:7528\:6696\:8272\:53d1\:5149\:5706\:76d8\:ff0c\
\:4f5c\:4e3a\:6574\:4e2a\:753b\:9762\:7684\:89c6\:89c9\:4e2d\:5fc3\:3002 *)
        {
          Glow[RGBColor[\"#ffd76a\"]],
          RGBColor[\"#ffb300\"],
          EdgeForm[None],
          Disk[{0, 0}, 0.22]
        }
      },
      Flatten@Table[
        {
          (* \:6bcf\:9897\:884c\:661f\:5148\:753b\:4e00\:6761\:6de1\:8272\
\:5706\:8f68\:9053\:ff0c\:5e2e\:52a9\:89c2\:5bdf\:516c\:8f6c\:5c42\:7ea7\:5173\
\:7cfb\:3002 *)
          {
            Directive[planet[\"\:8f68\:9053\:989c\:8272\"], Opacity[0.55], \
AbsoluteThickness[1.2]],
            Circle[{0, 0}, planet[\"\:8f68\:9053\:534a\:5f84\"]]
          },

          (* \:5982\:679c\:542f\:7528\:8f68\:8ff9\:ff0c\:5c31\:628a\:6700\
\:8fd1\:4e00\:6bb5\:8f68\:9053\:753b\:6210\:534a\:900f\:660e\:5f69\:8272\:7ebf\
\:6761\:3002 *)
          Sequence @@ If[
            showTrails,
            {
              {
                Directive[planet[\"\:989c\:8272\"], Opacity[0.38], \
AbsoluteThickness[2.0]],
                Line[trailPoints[planet, t]]
              }
            },
            {}
          ],

          (* \:5f53\:524d\:65f6\:523b\:7684\:884c\:661f\:4f4d\:7f6e\:4f7f\
\:7528\:5f69\:8272\:5706\:70b9\:8868\:793a\:3002 *)
          With[{pos = planetPosition[planet, t]},
            {
              {
                EdgeForm[Directive[White, Opacity[0.18]]],
                planet[\"\:989c\:8272\"],
                Disk[pos, planetDiskRadius[planet]]
              },

              (* \:884c\:661f\:540d\:79f0\:76f4\:63a5\:4f7f\:7528\:4e2d\:6587\
\:6807\:6ce8\:ff0c\:5e76\:7ed9\:4e00\:4e2a\:6df1\:8272\:80cc\:666f\:ff0c\:907f\
\:514d\:548c\:8f68\:8ff9\:6df7\:5728\:4e00\:8d77\:3002 *)
              Text[
                Style[
                  planet[\"\:4e2d\:6587\:540d\"],
                  12,
                  Bold,
                  White,
                  FontFamily -> \"Microsoft YaHei\",
                  Background -> Darker[planet[\"\:989c\:8272\"], 0.78]
                ],
                pos + planet[\"\:6807\:7b7e\:504f\:79fb\"]
              ]
            }
          ]
        },
        {planet, visiblePlanets}
      ]
    ],
    PlotRange -> {{-range, range}, {-range, range}},
    PlotRangePadding -> Scaled[0.04],
    Background -> RGBColor[\"#050814\"],
    ImagePadding -> 42,
    ImageSize -> 860,
    Axes -> False,
    PlotLabel -> Style[
      \"\:592a\:9633\:7cfb\:516b\:5927\:884c\:661f\:5f69\:8272\:8fd0\:884c\
\:8f68\:8ff9\",
      18,
      Bold,
      White,
      FontFamily -> \"Microsoft YaHei\"
    ]
  ]
];

(* Manipulate \:8d1f\:8d23\:751f\:6210\:4ea4\:4e92\:5f0f\:52a8\:753b\:63a7\
\:4ef6\:3002
   \:4e3a\:4e86\:4fbf\:4e8e\:6f14\:793a\:ff0c\:8fd9\:91cc\:63d0\:4f9b\:4e09\
\:4e2a\:4ea4\:4e92\:7ef4\:5ea6\:ff1a
   - \:6a21\:62df\:5e74\:4efd\:ff1a\:63a7\:5236\:52a8\:753b\:64ad\:653e\:8fdb\
\:5ea6\:ff1b
   - \:663e\:793a\:8f68\:8ff9\:ff1a\:5207\:6362\:662f\:5426\:663e\:793a\:5f69\
\:8272\:5c3e\:8ff9\:ff1b
   - \:89c6\:91ce\:8303\:56f4\:ff1a\:5207\:6362\:5185\:884c\:661f\:89c6\:56fe\
\:548c\:5168\:666f\:89c6\:56fe\:3002 *)
demoExpr = Manipulate[
  orbitGraphic[year, showTrails, zoom],
  {{
    year,
    0.,
    \"\:6a21\:62df\:5e74\:4efd\"
   },
   0.,
   165.,
   Animator,
   AnimationRunning -> False,
   AnimationRate -> 0.45,
   AppearanceElements -> {
     \"ProgressSlider\",
     \"PlayPauseButton\",
     \"FasterSlowerButtons\",
     \"DirectionButton\"
   }
  },
  {{
    showTrails,
    True,
    \"\:663e\:793a\:5f69\:8272\:8f68\:8ff9\"
   },
   {True -> \"\:663e\:793a\", False -> \"\:9690\:85cf\"}
  },
  {{
    zoom,
    12.,
    \"\:89c6\:91ce\:8303\:56f4\:ff08\:5929\:6587\:5355\:4f4d\:ff09\"
   },
   {
     2. -> \"\:5185\:884c\:661f\",
     4. -> \"\:706b\:661f\:4ee5\:5185\",
     8. -> \"\:6728\:661f\:4ee5\:5185\",
     12. -> \"\:571f\:661f\:4ee5\:5185\",
     20. -> \"\:5929\:738b\:661f\:4ee5\:5185\",
     32. -> \"\:5168\:666f\"
   }
  },
  TrackedSymbols :> {year, showTrails, zoom},
  SaveDefinitions -> True,
  ControlPlacement -> Left,
  Paneled -> False,
  SynchronousUpdating -> False
];

demoExpr\
